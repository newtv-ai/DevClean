{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reclaimer.invalid/schemas/broker-install-manifest.schema.json",
  "title": "Reclaimer future-G6 broker install manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "publisher_thumbprint",
    "installer_sha256",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "release_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+\\-]{0,63}$"
    },
    "publisher_thumbprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "installer_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1024,
      "contains": {
        "type": "object",
        "required": ["kind"],
        "properties": { "kind": { "const": "BROKER" } }
      },
      "minContains": 1,
      "maxContains": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relative_path", "kind", "sha256"],
        "properties": {
          "relative_path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "kind": { "enum": ["BROKER", "DLL"] },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
