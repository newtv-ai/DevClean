{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://DevClean.invalid/schemas/gate-evidence.schema.json",
  "title": "DevClean external safety-gate evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate",
    "run_id",
    "captured_at",
    "product",
    "prerequisites",
    "environment",
    "scope",
    "evidence",
    "checks",
    "review",
    "limitations",
    "conclusion"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1, "maxLength": 256 },
    "schema_version": { "const": "1.0.0" },
    "gate": { "enum": ["G0", "G1", "G2", "G5"] },
    "run_id": {
      "type": "string",
      "pattern": "^gate_run_[a-z0-9][a-z0-9_-]{7,95}$"
    },
    "captured_at": { "type": "string", "format": "date-time" },
    "product": { "$ref": "#/$defs/product" },
    "prerequisites": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/prerequisite" }
    },
    "environment": { "$ref": "#/$defs/environment" },
    "scope": { "$ref": "#/$defs/scope" },
    "evidence": {
      "type": "array",
      "maxItems": 512,
      "items": { "$ref": "#/$defs/evidence_item" }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/check" }
    },
    "review": { "$ref": "#/$defs/review" },
    "limitations": {
      "type": "array",
      "maxItems": 64,
      "items": { "type": "string", "minLength": 1, "maxLength": 1000 }
    },
    "conclusion": { "enum": ["PASS", "FAIL", "INCOMPLETE"] }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "opaque_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]{1,63}$"
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "source_revision", "artifact_kind", "artifact_sha256"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
        },
        "source_revision": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{6,127}$"
        },
        "artifact_kind": {
          "enum": ["WHEEL", "SOURCE_ARCHIVE", "INSTALLED_TREE"]
        },
        "artifact_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "machine_kind",
        "machine_fingerprint_sha256",
        "os_product",
        "os_version",
        "os_build",
        "architecture",
        "locale",
        "filesystem",
        "volume_kind",
        "user_integrity",
        "isolation_notes"
      ],
      "properties": {
        "machine_kind": { "enum": ["PHYSICAL", "DISPOSABLE_VM", "CI_RUNNER"] },
        "machine_fingerprint_sha256": { "$ref": "#/$defs/sha256" },
        "os_product": { "type": "string", "minLength": 3, "maxLength": 128 },
        "os_version": { "type": "string", "minLength": 3, "maxLength": 64 },
        "os_build": { "type": "string", "minLength": 3, "maxLength": 64 },
        "architecture": { "enum": ["x86_64", "arm64"] },
        "locale": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})+$"
        },
        "filesystem": { "enum": ["NTFS", "ReFS", "OTHER", "MIXED"] },
        "volume_kind": { "enum": ["FIXED", "REMOVABLE", "NETWORK", "MIXED"] },
        "user_integrity": { "enum": ["STANDARD", "ELEVATED"] },
        "isolation_notes": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapters",
        "available_adapters",
        "required_process_names",
        "managed_root_labels",
        "protected_asset_labels",
        "allowed_write_root_labels"
      ],
      "properties": {
        "adapters": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "available_adapters": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "required_process_names": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._()+\\-]{0,126}[A-Za-z0-9)]$"
          }
        },
        "managed_root_labels": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 128,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "protected_asset_labels": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 128,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "allowed_write_root_labels": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/opaque_id" }
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "kind",
        "relative_path",
        "sha256",
        "bytes",
        "contains_sensitive_data",
        "description"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^gate_evidence_[a-z0-9][a-z0-9_-]{7,95}$"
        },
        "kind": {
          "enum": [
            "PRODUCT_ARTIFACT",
            "PROCMON_PML",
            "PROCMON_CSV",
            "PROCMON_FILTER_SCREENSHOT",
            "PROCMON_VALIDATION_JSON",
            "SCAN_REPORT_JSON",
            "TEST_REPORT_JSON",
            "BENCHMARK_JSON",
            "BOUNDARY_OBSERVATION_JSON",
            "SERVICE_STATE_BEFORE_JSON",
            "SERVICE_STATE_AFTER_JSON",
            "GATE_RESULT_JSON",
            "OWNER_ATTESTATION_JSON",
            "SOURCE_AUDIT_JSON",
            "CI_ATTESTATION_JSON",
            "CODEQL_ATTESTATION_JSON",
            "DEPENDENCY_AUDIT_JSON",
            "RELEASE_VALIDATION_JSON",
            "VOLUME_INVENTORY_JSON",
            "RACE_REPORT_JSON",
            "CANARY_ATTESTATION_JSON",
            "STATIC_AUDIT_REPORT",
            "REVIEW_ATTESTATION",
            "SCREENSHOT_PNG",
            "OTHER"
          ]
        },
        "relative_path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$",
          "maxLength": 512
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 },
        "contains_sensitive_data": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "status",
        "required",
        "evidence_refs",
        "explanation"
      ],
      "properties": {
        "check_id": { "$ref": "#/$defs/opaque_id" },
        "status": { "enum": ["PASS", "FAIL", "SKIP"] },
        "required": { "type": "boolean" },
        "iterations": { "type": "integer", "minimum": 1 },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 64,
          "items": {
            "type": "string",
            "pattern": "^gate_evidence_[a-z0-9][a-z0-9_-]{7,95}$"
          }
        },
        "explanation": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "author_ids",
        "reviewer_ids",
        "review_method",
        "reviewed_at",
        "notes"
      ],
      "properties": {
        "author_ids": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 32,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "reviewer_ids": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 32,
          "items": { "$ref": "#/$defs/opaque_id" }
        },
        "review_method": { "enum": ["HUMAN", "MULTI_MODEL", "NONE"] },
        "reviewed_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "notes": { "type": "string", "maxLength": 2000 }
      }
    },
    "prerequisite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "evidence_ref"],
      "properties": {
        "gate": { "enum": ["G0", "G1", "G2", "G3", "G4"] },
        "evidence_ref": {
          "type": "string",
          "pattern": "^gate_evidence_[a-z0-9][a-z0-9_-]{7,95}$"
        }
      }
    }
  }
}
